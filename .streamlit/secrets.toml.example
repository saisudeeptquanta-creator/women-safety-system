# ===========================================================================
#  SECRETS TEMPLATE  —  copy the contents you need into the Streamlit Cloud
#  "Secrets" box (App → Settings → Secrets), or into a LOCAL
#  .streamlit/secrets.toml file for local testing.
#
#  Do NOT commit a real secrets.toml — it is gitignored on purpose.
#  Everything here is OPTIONAL: the app runs without it using a local
#  JSON store and simulated contact notifications.
# ===========================================================================

# ---- Firebase Firestore (enables real-time cloud database) ----------------
# Paste the values from your downloaded service-account JSON key.
# Keep the \n escapes inside private_key exactly as shown.
[firebase]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...your...key...\n-----END PRIVATE KEY-----\n"
client_email = "firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."

# ---- Email alerts via Gmail SMTP (enables real emails to contacts) --------
# Use a Gmail "App Password" (16 chars), NOT your normal password.
[email]
sender = "yourgmail@gmail.com"
app_password = "abcd efgh ijkl mnop"

# ---- Telegram bot (FREE) — phone alerts even when the app/browser is CLOSED
# 1) In Telegram, message @BotFather -> /newbot -> copy the bot token below.
# 2) Open your new bot and tap Start.
# 3) Get your numeric chat ID from @userinfobot and enter it in the app
#    (Emergency Contacts -> "My Telegram chat ID"). Contacts do the same.
[telegram]
bot_token = "123456789:ABCdefGhIJKlmNoPQRsTUVwxyz"

# ---- Twilio (OPTIONAL) — SMS to any phone + a real ringing CALL -----------
# A phone call is the closest thing to a "loud siren" on a fully closed phone.
# Free trial credit available at https://www.twilio.com/try-twilio
[twilio]
account_sid = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
auth_token = "your_twilio_auth_token"
from_number = "+1XXXXXXXXXX"   # your Twilio number
